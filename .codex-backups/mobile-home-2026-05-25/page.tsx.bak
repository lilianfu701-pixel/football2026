                className="inline-flex min-h-12 items-center justify-center gap-2 rounded-lg bg-[#FFD700] px-6 py-3 text-sm font-black text-[#081120] shadow-[0_18px_45px_rgba(255,215,0,0.22)] transition hover:bg-[#FFC928]"
              >
                {user ? c.primaryUser : c.primaryGuest}
                <ArrowRight className="h-4 w-4" />
              </Link>
              <Link
                href={`/${locale}/matches`}
                className="inline-flex min-h-12 items-center justify-center gap-2 rounded-lg border border-white/15 bg-white/8 px-6 py-3 text-sm font-bold text-white backdrop-blur transition hover:border-[#FFD700]/50 hover:bg-white/12"
              >
                <CalendarDays className="h-4 w-4" />
