          <div className="grid gap-4 sm:grid-cols-2">
            <div className="rounded-lg border border-white/10 bg-[#081120] p-5">
              <div className="relative mb-5 aspect-square max-h-52 overflow-hidden rounded-lg bg-[#FFD700]/10">
