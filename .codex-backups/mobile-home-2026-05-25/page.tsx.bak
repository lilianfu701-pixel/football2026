              </Link>
            </div>

            {!user && (
              <div className="mt-6 flex max-w-xl items-center gap-3 rounded-lg border border-emerald-300/25 bg-emerald-300/10 px-4 py-3 text-sm font-semibold text-emerald-100">
                <Gift className="h-5 w-5 shrink-0 text-[#FFD700]" />
                {c.gift}
              </div>
            )}

            <div className="mt-10 grid max-w-2xl grid-cols-3 gap-3">
              {[
                { value: c.matches, label: c.matchesLabel },
                { value: c.teams, label: c.teamsLabel },
                { value: c.coins, label: c.coinsLabel },
