function TeamBlock({
  code,
  name,
  tone,
  align = "left",
}: {
  code: string;
  name: string;
  tone: string;
  align?: "left" | "right";
}) {
  return (
    <div className={`flex items-center gap-3 ${align === "right" ? "flex-row-reverse text-right" : ""}`}>
      <div className={`flex h-12 w-12 items-center justify-center rounded-lg ${tone} text-xs font-black text-white`}>
        {code}
      </div>
      <div>
        <div className="text-sm font-black text-white">{name}</div>
        <div className="mt-1 text-xs text-slate-400">2026</div>
      </div>
    </div>
  );
}
