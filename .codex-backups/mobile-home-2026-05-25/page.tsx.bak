        <div className="absolute inset-x-0 bottom-0 h-36 bg-gradient-to-t from-[#081120] to-transparent" />
        <div className="relative mx-auto grid max-w-7xl grid-cols-1 gap-10 px-4 pb-16 pt-10 sm:px-6 lg:grid-cols-[1.02fr_0.98fr] lg:items-center lg:pt-16">
          <div className="max-w-3xl">
            <div className="mb-6 inline-flex items-center gap-2 rounded-full border border-[#FFD700]/40 bg-[#FFD700]/12 px-4 py-2 text-sm font-semibold text-[#FFD700]">
              <Trophy className="h-4 w-4" />
