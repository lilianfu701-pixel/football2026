"use client";

import {
  CalendarDays,
  CheckCircle2,
  ChevronRight,
  CircleDollarSign,
  Flame,
  Gift,
  Home,
  MessageCircle,
  Sparkles,
  Trophy,
  UserRound,
} from "lucide-react";
import Image from "next/image";
import Link from "next/link";
import { useEffect, useState } from "react";
import { useGcBalance } from "@/context/GcBalance";
import MobileInstallPrompt from "@/components/mobile/MobileInstallPrompt";

declare global {
  interface Navigator {
    standalone?: boolean;
  }
}

interface MobileHomeProps {
  locale: string;
  isLoggedIn: boolean;
  daysLeft: string;
}

